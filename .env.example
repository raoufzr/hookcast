# --- Database ---
DATABASE_URL="postgresql://hookcast:hookcast@localhost:5432/hookcast"

# --- Auth (NextAuth) ---
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# --- Claude (Anthropic) — powers all analysis, hook/script rewrites ---
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-sonnet-4-6"

# --- Platform data sources ---
# YouTube Data API v3 key. Without it, YouTube falls back to oEmbed
# (title/author/thumbnail only — no view/like counts).
YOUTUBE_API_KEY=""
# TikTok and Instagram do not offer a public, key-based metadata API
# for arbitrary public videos. TikTok uses oEmbed (no key required,
# limited fields). Instagram has no public unauthenticated endpoint,
# so its adapter accepts manually pasted stats as a fallback — see
# lib/platforms/instagram.ts and /docs/ARCHITECTURE.md.

# --- Stripe ---
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PRICE_PRO=""
NEXT_PUBLIC_STRIPE_PRICE_AGENCY=""
NEXT_PUBLIC_APP_URL="http://localhost:3000"
